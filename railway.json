{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "/ui-tui/**",
      "/Dockerfile",
      "/docker/**",
      "/package.json",
      "/package-lock.json",
      "/pyproject.toml",
      "/uv.lock",
      "/railway.json",
      "/web/**"
    ],
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "npm run start --workspace=hermes-tui",
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
